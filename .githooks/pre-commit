#!/usr/bin/env sh
# Signal Library pre-commit hook.
# 1. Hard validation (validate_signals.cli) — BLOCKS commit on failure.
# 2. Soft lint (validate_signals.lint) — warnings only, never blocks.

set -e

# Get list of staged .md files under signals/active/
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^signals/active/.*\.md$' || true)

if [ -z "$staged" ]; then
  exit 0
fi

# 1. Hard validation — blocks on failure
python -m validate_signals.cli $staged --taxonomy signals/_taxonomy.yml

# 2. Soft lint — advisory only (always exits 0)
python -m validate_signals.lint $staged || true
